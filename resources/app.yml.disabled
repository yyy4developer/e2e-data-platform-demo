resources:
  apps:
    experiment_app:
      name: "e2e-experiment-app"
      description: "材料実験条件の予測・推薦アプリ"
      source_code_path: ../app

      resources:
        - name: "serving-endpoint"
          description: "実験予測モデルのServing Endpoint"
          serving_endpoint:
            name: "e2e-experiment-predictor"
            permission: "CAN_QUERY"
